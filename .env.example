# ── Local development defaults ──────────────────────────────────────────────
# Points at the bundled embedded-postgres instance started by `npm run db:local`.
DATABASE_URL="postgresql://finance:finance@localhost:5433/finance"

# Auth.js. Generate a real secret with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="generate-with-npx-auth-secret"

# Public demo deployment. When "true":
#   - No authentication required — all visitors see the same seeded demo data.
#   - Any mutations (add transaction, set budget, etc.) are reflected in the browser
#     only and never written to the database, so the demo stays consistent.
#   - Plaid, AI assistant, Settings, and backup/export are hidden.
#   - Requires running `npm run db:seed` once to populate the demo data.
# Set AUTH_BYPASS="true" as well so visitors aren't prompted to sign in.
DEMO_MODE="false"

# Skip the sign-in screen entirely for local-only use. When "true", any visit
# automatically signs in as LOCAL_USER_NAME — no password required. Safe for
# personal local use; set "false" if you ever expose the app to the internet.
AUTH_BYPASS="true"

# Your name — used as the display name and to derive your local account identity.
# Change this to your first name or first + last (e.g. "Jane" or "Jane Doe").
LOCAL_USER_NAME="local"

# Plaid API credentials — optional instance-wide fallback. Each user can store
# their own keys in Settings → Plaid bank sync (encrypted in the database);
# these env values are only used for users who haven't saved their own.
# Copy from https://dashboard.plaid.com/team/keys — use the Sandbox or
# Production secret that matches PLAID_ENV below.
#   sandbox    = free test banks with fake data (good for trying it out)
#   production = your real banks (requires Plaid approval; billed per linked item)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
