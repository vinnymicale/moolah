# ── Local development defaults ──────────────────────────────────────────────
# Points at the bundled embedded-postgres instance started by `npm run db:local`.
DATABASE_URL="postgresql://finance:finance@localhost:5433/finance"

# Auth.js. Generate a real secret with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="generate-with-npx-auth-secret"

# Google OAuth credentials (see README for how to create these).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Public base URL of the app.
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated allow-list of emails permitted to sign in (you + your wife).
# Leave blank to allow anyone with the invite code.
ALLOWED_EMAILS=""

# Skip login entirely for local-only use. When "true", any visit automatically
# signs in as LOCAL_USER_EMAIL (default: local@moolah.local) — no Google OAuth
# or password required. Safe for personal local use; set "false" if you ever
# expose the app to the internet.
AUTH_BYPASS="true"

# The email used for the auto-login account when AUTH_BYPASS=true.
# Change this if you want a custom name/email for your local account.
# Leave blank to use the default (local@moolah.local).
LOCAL_USER_EMAIL="local@moolah.local"

# Password-less local sign-in so you can use the app before Google is set up.
# Not needed when AUTH_BYPASS=true (bypass enables this automatically).
AUTH_DEV_LOGIN="true"

# Plaid API credentials. Copy from https://dashboard.plaid.com/team/keys — use
# the Sandbox or Production secret that matches PLAID_ENV below.
#   sandbox    = free test banks with fake data (good for trying it out)
#   production = your real banks (requires Plaid approval; billed per linked item)
# Plaid's old "development" environment has been retired, so it's not an option.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
