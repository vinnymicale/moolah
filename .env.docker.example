# Docker Compose configuration for self-hosting Moolah.
# Copy to .env in the same directory as docker-compose.yml, then `docker compose up -d`.

# REQUIRED. Generate a real secret with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="generate-with-npx-auth-secret"

# Postgres credentials for the bundled database container. The app's DATABASE_URL
# is assembled from these in docker-compose.yml — no need to set it yourself.
# (Compose sets DATABASE_URL on the app service directly, so it always points at
# the bundled db container and ignores any DATABASE_URL in a repo-root .env.)
POSTGRES_USER="finance"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="finance"

# Host port to expose the app on (http://localhost:<APP_PORT>).
APP_PORT="3000"

# Host folder for scheduled local backups (mounted to /backups in the container).
# Defaults to ./backups next to docker-compose.yml. Point it anywhere you want the
# backup files to live on the host — each is a full JSON dump including Plaid
# tokens, so keep it private.
BACKUP_HOST_DIR="./backups"

# Skip the sign-in screen for single-user self-hosting. Set "false" if you expose
# Moolah to the internet and want password protection.
AUTH_BYPASS="true"
LOCAL_USER_NAME="local"

# Public demo mode — leave "false" for normal self-hosted use.
DEMO_MODE="false"

# Optional instance-wide Plaid fallback. Each user can also set their own keys in
# Settings → Plaid bank sync. Leave blank if you don't use bank sync.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
