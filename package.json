{
  "name": "moolah",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start:all": "concurrently -k -n db,web -c blue,green \"npm:db:local\" \"npm:dev\"",
    "dev": "next dev",
    "postinstall": "prisma generate",
    "setup": "tsx scripts/setup.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:prod": "concurrently -k -n db,web -c blue,green \"npm:db:local\" \"npm:start\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:local": "tsx scripts/local-db.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:backup": "tsx scripts/export-data.ts",
    "db:restore": "tsx scripts/import-data.ts",
    "db:snapshot-backfill": "tsx scripts/backfill-snapshots.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "node-cron": "^4.5.0",
    "pg": "^8.22.0",
    "plaid": "^42.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "embedded-postgres": "^18.3.0-beta.17",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
