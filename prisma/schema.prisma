// Personal Finance & Net Worth Tracker — data model
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth (Auth.js / NextAuth models)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())

  // AI assistant configuration — user-supplied key, never sent to the browser.
  aiProvider    String?   // "anthropic" | "openai" | "gemini"
  aiApiKey      String?

  // Plaid credentials — per-user so each account links banks against their own
  // Plaid developer account. Secret is encrypted at rest; falls back to the
  // PLAID_* env vars when unset.
  plaidClientId String?
  plaidSecret   String?
  plaidEnv      String?   // "sandbox" | "production"

  accounts          Account[] // OAuth accounts (Auth.js)
  sessions          Session[]
  financialAccounts FinancialAccount[]
  categories        Category[]
  transactions      Transaction[]
  recurring         RecurringRule[]
  budgets           Budget[]
  savingsGoals      SavingsGoal[]
  plaidItems        PlaidItem[]
  categoryRules     CategoryRule[]
}

// Auth.js OAuth account link
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Financial domain
// ---------------------------------------------------------------------------

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  RETIREMENT
  INVESTMENT
  VEHICLE
  PROPERTY
  LOAN
  CASH
  OTHER_ASSET
  OTHER_LIABILITY
}

enum TxnType {
  INCOME
  EXPENSE
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model FinancialAccount {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  type           AccountType
  institution    String?
  // Current balance. For liabilities (credit cards, loans) store a positive
  // number representing the amount owed; isAsset distinguishes the sign for
  // net-worth math.
  currentBalance Decimal     @default(0) @db.Decimal(14, 2)
  isAsset        Boolean     @default(true)
  // Include this account's running balance in the calendar cash projection
  // (typically checking / savings / cash).
  includeInCash  Boolean     @default(false)
  // Include this account's balance in net-worth totals. Lets the user track an
  // account (e.g. a student loan) without it dragging down their net worth.
  includeInNetWorth Boolean  @default(true)
  // Whether this account appears on the Debt Payoff page (liability types only).
  includeInDebtPlanner Boolean @default(true)
  // Debt-only fields powering the payoff planner. Annual interest rate as a
  // percentage (e.g. 19.99) and the minimum monthly payment. Null for assets.
  interestRate   Decimal?    @db.Decimal(6, 3)
  minimumPayment Decimal?    @db.Decimal(14, 2)
  // Credit card fields — populated from Plaid Liabilities on each sync.
  creditLimit           Decimal?  @db.Decimal(14, 2)
  lastStatementBalance  Decimal?  @db.Decimal(14, 2)
  lastStatementDate     DateTime?
  lastPaymentAmount     Decimal?  @db.Decimal(14, 2)
  lastPaymentDate       DateTime?
  nextPaymentDueDate    DateTime?
  isOverdue             Boolean?
  color          String      @default("#64748b")
  archived       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  snapshots           AccountSnapshot[]
  transactions        Transaction[]
  recurring           RecurringRule[]
  plaidLinkedAccounts PlaidLinkedAccount[]

  @@index([userId])
}

model AccountSnapshot {
  id        String           @id @default(cuid())
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime
  balance   Decimal          @db.Decimal(14, 2)
  note      String?
  createdAt DateTime         @default(now())

  @@index([accountId, date])
}

model Category {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  kind        CategoryKind
  color       String       @default("#64748b")
  icon        String       @default("tag")
  isSystem    Boolean      @default(false)

  parentId    String?
  parent      Category?    @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]   @relation("CategoryChildren")

  transactions Transaction[]
  recurring    RecurringRule[]
  budgets      Budget[]
  rules        CategoryRule[]

  @@index([userId])
}

// User-defined auto-categorization: when a transaction description contains
// `pattern` (case-insensitive), assign `categoryId`. Applied on Plaid sync and
// CSV import; rules take precedence over Plaid's generic category mapping.
model CategoryRule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  pattern     String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@index([userId])
}

model Transaction {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId       String?
  account         FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  type            TxnType
  amount          Decimal       @db.Decimal(14, 2)
  date            DateTime
  description     String
  note            String?
  // false = still expected / projected, true = actually happened.
  cleared         Boolean       @default(true)

  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  // Set when the transaction was imported via Plaid. Null for manual/CSV entries.
  plaidTransactionId    String?  @unique
  plaidPrimaryCategory  String?
  plaidDetailedCategory String?

  // Transfer pairing: a CC payment leaving checking linked to the matching
  // credit on the card. Both sides are excluded from income/expense totals.
  isTransfer      Boolean       @default(false)
  transferPeerId  String?       @unique
  transferPeer    Transaction?  @relation("TransferPair", fields: [transferPeerId], references: [id], onDelete: SetNull)
  transferPeerOf  Transaction?  @relation("TransferPair")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
}

model RecurringRule {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId    String?
  account      FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  type         TxnType
  amount       Decimal    @db.Decimal(14, 2)
  description  String
  note         String?

  frequency    Frequency
  interval     Int        @default(1) // every N units of frequency
  startDate    DateTime
  endDate      DateTime?
  // Anchor day of month for MONTHLY/YEARLY (1-31); ignored otherwise.
  dayOfMonth   Int?
  // Anchor weekday for WEEKLY/BIWEEKLY (0=Sun..6=Sat); ignored otherwise.
  weekday      Int?

  archived     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  transactions Transaction[]

  @@index([userId])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // First day of the budgeted month (UTC midnight).
  month       DateTime
  limit       Decimal  @db.Decimal(14, 2)

  @@unique([userId, categoryId, month])
  @@index([userId])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  targetAmount  Decimal   @db.Decimal(14, 2)
  // Amount saved so far. Updated manually via contributions.
  currentAmount Decimal   @default(0) @db.Decimal(14, 2)
  targetDate    DateTime?
  color         String    @default("#16a34a")
  icon          String    @default("piggy-bank")
  archived      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

// ── Plaid bank connections ────────────────────────────────────────────────────

model PlaidItem {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The Plaid access token is server-side only — never exposed to the browser.
  accessToken     String
  itemId          String    @unique
  institutionId   String?
  institutionName String?
  // Cursor for /transactions/sync — null means "first sync not yet done".
  cursor          String?
  lastSyncedAt    DateTime?
  error           String?   // last sync error message, if any

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  linkedAccounts  PlaidLinkedAccount[]

  @@index([userId])
}

model PlaidLinkedAccount {
  id                 String            @id @default(cuid())
  plaidItemId        String
  plaidItem          PlaidItem         @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)

  // Plaid's stable identifier for this account (used for dedup).
  plaidAccountId     String            @unique
  // The local FinancialAccount this syncs into. Null until linked by the user.
  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)

  name               String
  officialName       String?
  mask               String?  // last 4 digits
  plaidType          String   // depository | credit | loan | investment | other
  plaidSubtype       String?  // checking | savings | credit card | …
  // Balances as reported by Plaid (updated on each sync).
  availableBalance   Decimal? @db.Decimal(14, 2)
  currentBalance     Decimal? @db.Decimal(14, 2)
  creditLimit        Decimal? @db.Decimal(14, 2)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([plaidItemId])
}
